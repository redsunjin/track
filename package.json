{
  "name": "track",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src",
    "agents",
    "docs",
    "vscode-extension",
    "README.md",
    "AGENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/packages/agents.d.ts",
      "import": "./dist/packages/agents.js"
    },
    "./bot-bridge": {
      "types": "./dist/packages/bot-bridge.d.ts",
      "import": "./dist/packages/bot-bridge.js"
    },
    "./cli": {
      "types": "./dist/packages/cli.d.ts",
      "import": "./dist/packages/cli.js"
    },
    "./core": {
      "types": "./dist/packages/core.d.ts",
      "import": "./dist/packages/core.js"
    },
    "./mcp": {
      "types": "./dist/packages/mcp.d.ts",
      "import": "./dist/packages/mcp.js"
    },
    "./openclaw-adapter": {
      "types": "./dist/packages/openclaw-adapter.d.ts",
      "import": "./dist/packages/openclaw-adapter.js"
    },
    "./openclaw-live": {
      "types": "./dist/packages/openclaw-live.d.ts",
      "import": "./dist/packages/openclaw-live.js"
    },
    "./openclaw-monitor": {
      "types": "./dist/packages/openclaw-monitor.d.ts",
      "import": "./dist/packages/openclaw-monitor.js"
    },
    "./package-layout": {
      "types": "./dist/package-layout.d.ts",
      "import": "./dist/package-layout.js"
    },
    "./pitwall-monitor": {
      "types": "./dist/packages/pitwall-monitor.d.ts",
      "import": "./dist/packages/pitwall-monitor.js"
    },
    "./runtime": {
      "types": "./dist/packages/runtime.d.ts",
      "import": "./dist/packages/runtime.js"
    },
    "./vscode": "./vscode-extension/dist/extension.js"
  },
  "bin": {
    "track": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "buddy": "node --import tsx ./src/cli.ts buddy",
    "check:harness": "node --import tsx ./src/cli.ts check:harness",
    "companion": "node --import tsx ./src/cli.ts companion",
    "import": "node --import tsx ./src/cli.ts import",
    "lab": "node --import tsx ./src/cli.ts lab",
    "mcp:smoke": "node --import tsx ./src/cli.ts mcp-smoke-test",
    "package:build-check": "npm run build && npm run vscode:build && node dist/cli.js package dry-run",
    "package:check": "node --import tsx ./src/cli.ts package check",
    "package:dry-run": "npm run package:build-check",
    "package:handoff": "node --import tsx ./src/cli.ts package handoff",
    "package:install-smoke": "node scripts/package-install-smoke.mjs",
    "package:publish-guard": "node --import tsx ./src/cli.ts package publish-guard",
    "package:readiness": "node --import tsx ./src/cli.ts package readiness",
    "status": "node --import tsx ./src/cli.ts status",
    "next": "node --import tsx ./src/cli.ts next",
    "map": "node --import tsx ./src/cli.ts map",
    "pitwall": "node --import tsx ./src/cli.ts pitwall",
    "test": "npm run build && node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "vscode:build": "tsc -p vscode-extension/tsconfig.json",
    "vscode:check": "tsc -p vscode-extension/tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
