{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Track Companion Extension Host",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "preLaunchTask": "npm: vscode:build"
    }
  ]
}
